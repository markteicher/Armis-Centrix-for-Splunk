flowchart TB

%% Root
A[Armis API v1] --> AUTH[Authentication<br/>Access Token]

%% Core Domains
AUTH --> ALERTS[Alerts]
AUTH --> DEVICES[Devices]
AUTH --> USERS[Users]
AUTH --> VULNS[Vulnerabilities]
AUTH --> BOUNDARIES[Boundaries]
AUTH --> INTEGRATIONS[Integrations]
AUTH --> POLICIES[Policies]
AUTH --> REPORTS[Reports]
AUTH --> ROLES[Roles]
AUTH --> SEARCH[Search]
AUTH --> SITES[Sites]
AUTH --> COLLECTORS[Collectors]

%% Alerts
ALERTS --> ALERT_LIST[GET /alerts]
ALERT_LIST --> ALERTS_ARRAY[alerts[]]
ALERT_LIST --> ALERT_PAGINATION[pagination<br/>count / next / prev]

ALERTS --> ALERT_ACTION[PUT /alerts/{alert_id}]
ALERT_ACTION --> ALERT_ID[alert_id<br/>(path, required)]
ALERT_ACTION --> ALERT_STATUS[status<br/>UNHANDLED<br/>SUPPRESSED<br/>RESOLVED]

%% Devices
DEVICES --> DEVICE_LIST[GET /devices]
DEVICE_LIST --> DEVICES_ARRAY[devices[]]
DEVICE_LIST --> DEVICE_PAGINATION[pagination]

DEVICES_ARRAY --> DEVICE_CORE[id<br/>name<br/>type<br/>riskLevel]
DEVICES_ARRAY --> DEVICE_NETWORK[ip<br/>mac<br/>protocols]
DEVICES_ARRAY --> DEVICE_OS[os<br/>firmware]
DEVICES_ARRAY --> DEVICE_SITE[siteId]
DEVICES_ARRAY --> DEVICE_BOUNDARIES[boundaryIds]
DEVICES_ARRAY --> DEVICE_TAGS[tagIds]

%% Device Sub-Resources
DEVICES --> DEVICE_APPS[GET /device-applications]
DEVICES --> DEVICE_PROPERTIES[GET /device-properties]
DEVICES --> DEVICE_BOUNDARIES_MAP[GET /device-boundaries]

%% Vulnerabilities
VULNS --> VULN_LIST[GET /vulnerabilities]
VULN_LIST --> VULNS_ARRAY[vulnerabilities[]]
VULN_LIST --> VULN_PAGINATION[pagination]

VULNS_ARRAY --> VULN_ID[id]
VULNS_ARRAY --> VULN_SEVERITY[severity]
VULNS_ARRAY --> VULN_CVE[cve]
VULNS_ARRAY --> VULN_DEVICE[deviceId]

%% Users
USERS --> USER_LIST[GET /users]
USER_LIST --> USERS_ARRAY[users[]]
USER_LIST --> USER_PAGINATION[pagination]

USERS_ARRAY --> USER_ID[id]
USERS_ARRAY --> USER_EMAIL[email]
USERS_ARRAY --> USER_ROLE[role]
USERS_ARRAY --> USER_STATUS[isActive]
USERS_ARRAY --> USER_2FA[twoFactorAuthentication]

%% Boundaries
BOUNDARIES --> BOUNDARY_LIST[GET /boundaries]
BOUNDARY_LIST --> BOUNDARIES_ARRAY[boundaries[]]
BOUNDARY_LIST --> BOUNDARY_PAGINATION[pagination]

BOUNDARIES_ARRAY --> BOUNDARY_ID[id]
BOUNDARIES_ARRAY --> BOUNDARY_NAME[name]
BOUNDARIES_ARRAY --> BOUNDARY_TYPE[type]

%% Integrations
INTEGRATIONS --> INTEGRATION_LIST[GET /integrations]
INTEGRATION_LIST --> INTEGRATIONS_ARRAY[integrations[]]
INTEGRATION_LIST --> INTEGRATION_PAGINATION[pagination]

INTEGRATIONS_ARRAY --> INTEGRATION_ID[id]
INTEGRATIONS_ARRAY --> INTEGRATION_NAME[name]
INTEGRATIONS_ARRAY --> INTEGRATION_STATE[integrationState]
INTEGRATIONS_ARRAY --> INTEGRATION_STATS[statistics]

%% Policies
POLICIES --> POLICY_LIST[GET /policies]
POLICY_LIST --> POLICIES_ARRAY[policies[]]

%% Reports
REPORTS --> REPORT_LIST[GET /reports]
REPORT_LIST --> REPORTS_ARRAY[reports[]]

%% Roles
ROLES --> ROLE_LIST[GET /roles]
ROLE_LIST --> ROLES_ARRAY[roles[]]

%% Search
SEARCH --> SEARCH_QUERY[POST /search]
SEARCH_QUERY --> SEARCH_RESULTS[entities[]]

%% Sites
SITES --> SITE_LIST[GET /sites]
SITE_LIST --> SITES_ARRAY[sites[]]

%% Collectors
COLLECTORS --> COLLECTOR_LIST[GET /collectors]
COLLECTOR_LIST --> COLLECTORS_ARRAY[collectors[]]
