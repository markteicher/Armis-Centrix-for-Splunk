flowchart LR

%% =====================
%% CORE ENTRY
%% =====================
API[Armis API v1]

%% =====================
%% ALERTS
%% =====================
API --> ALERTS_ENDPOINT[Alerts]
ALERTS_LIST --> ALERT[Alert]
ALERT --> ALERT_ID[alert_id]
ALERT --> ALERT_STATUS[status]
ALERT_STATUS --> STATUS_UNHANDLED[UNHANDLED]
ALERT_STATUS --> STATUS_SUPPRESSED[SUPPRESSED]
ALERT_STATUS --> STATUS_RESOLVED

%% =====================
%% DEVICES
%% =====================
API --> DEVICES_ENDPOINT[Devices]

DEVICES_LIST --> DEVICE[Device]
DEVICE --> DEVICE_ID[device_id]
DEVICE --> DEVICE_NAME[name]
DEVICE --> DEVICE_IP[ip_address]
DEVICE --> DEVICE_MAC[mac_address]
DEVICE --> DEVICE_OS[operating_system]
DEVICE --> DEVICE_RISK[risk_level]
DEVICE --> DEVICE_SITE[site]
DEVICE --> DEVICE_TAGS[tags]
DEVICE --> DEVICE_BOUNDARIES[boundaries]

%% =====================
%% VULNERABILITIES
%% =====================
API --> VULNS_ENDPOINT[Vulnerabilities]

VULNS_LIST --> VULN[Vulnerability]
VULN --> VULN_DEVICE_ID[device_id]
VULN --> VULN_CVE[cve_uid]
VULN --> VULN_ADVISORY[advisory_id]
VULN --> VULN_STATUS[status]
VULN --> VULN_AVM[avm_rating]
VULN --> VULN_REMEDIATION[remediation_types]
VULN --> VULN_MATCH_SOURCE[match_source]
VULN --> VULN_STATUS_TIME[status_change_time]

DEVICE --> VULN

%% =====================
%% BOUNDARIES
%% =====================
API --> BOUNDARIES_ENDPOINT[Boundaries]

BOUNDARIES_LIST --> BOUNDARY[Boundary]
BOUNDARY --> BOUNDARY_ID[id]
BOUNDARY --> BOUNDARY_NAME[name]
BOUNDARY --> BOUNDARY_RULE[rule_aql]

DEVICE --> BOUNDARY

%% =====================
%% POLICIES
%% =====================
API --> POLICIES_ENDPOINT[Policies]

POLICIES_LIST --> POLICY[Policy]
POLICY --> POLICY_ID[id]
POLICY --> POLICY_NAME[name]
POLICY --> POLICY_ENABLED[is_enabled]
POLICY --> POLICY_ACTION[action]
POLICY --> POLICY_RULES[rules]

POLICY --> ALERT

%% =====================
%% INTEGRATIONS
%% =====================
API --> INTEGRATIONS_ENDPOINT[Integrations]

INTEGRATIONS_LIST --> INTEGRATION[Integration]
INTEGRATION --> INTEGRATION_ID[id]
INTEGRATION --> INTEGRATION_NAME[name]
INTEGRATION --> INTEGRATION_STATE[state]
INTEGRATION --> INTEGRATION_STATS[statistics]

INTEGRATION --> DEVICE

%% =====================
%% SITES
%% =====================
API --> SITES_ENDPOINT[Sites]

SITES_LIST --> SITE[Site]
SITE --> SITE_ID[id]
SITE --> SITE_NAME[name]
SITE --> SITE_LOCATION[location]

SITE --> DEVICE

%% =====================
%% USERS
%% =====================
API --> USERS_ENDPOINT[Users Endpoint]

USERS_LIST --> USER[User]
USER --> USER_ID[id]
USER --> USER_NAME[name]
USER --> USER_EMAIL[email]
USER --> USER_ROLE[role]

%% =====================
%% ROLES
%% =====================
API --> ROLES_ENDPOINT[Roles Endpoint]

ROLES_LIST --> ROLE[Role]
ROLE --> ROLE_NAME[name]
ROLE --> ROLE_PERMISSIONS[permissions]

ROLE --> USER
