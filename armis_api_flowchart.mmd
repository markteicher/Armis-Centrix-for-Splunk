flowchart TB

%% Root
A[Armis API v1] --> AUTH[Authentication<br/>Access Token]

%% Core API Domains
AUTH --> ALERTS[Alerts]
AUTH --> DEVICES[Devices]
AUTH --> USERS[Users]
AUTH --> VULNS[Vulnerabilities]
AUTH --> BOUNDARIES[Boundaries]
AUTH --> INTEGRATIONS[Integrations]
AUTH --> POLICIES[Policies]
AUTH --> REPORTS[Reports]
AUTH --> ROLES[Roles]
AUTH --> SEARCH[Search]
AUTH --> SITES[Sites]
AUTH --> COLLECTORS[Collectors]

%% Alerts
ALERTS --> ALERT_LIST[GET /alerts]
ALERT_LIST --> ALERT_ARRAY[alerts (array)]
ALERT_LIST --> ALERT_PAGINATION[pagination<br/>count / next / prev]

ALERTS --> ALERT_UPDATE[PUT /alerts/{alert_id}]
ALERT_UPDATE --> ALERT_ID[alert_id<br/>path parameter]
ALERT_UPDATE --> ALERT_STATUS[status<br/>UNHANDLED<br/>SUPPRESSED<br/>RESOLVED]

%% Devices
DEVICES --> DEVICE_LIST[GET /devices]
DEVICE_LIST --> DEVICE_ARRAY[devices (array)]
DEVICE_LIST --> DEVICE_PAGINATION[pagination]

DEVICE_ARRAY --> DEVICE_ID[id]
DEVICE_ARRAY --> DEVICE_NETWORK[ip / mac]
DEVICE_ARRAY --> DEVICE_PROTOCOLS[protocols]
DEVICE_ARRAY --> DEVICE_OS[os / firmware]
DEVICE_ARRAY --> DEVICE_SITE[siteId]
DEVICE_ARRAY --> DEVICE_BOUNDARIES[boundaryIds]
DEVICE_ARRAY --> DEVICE_TAGS[tagIds]

%% Device Sub-Resources
DEVICES --> DEVICE_APPS[GET /device-applications]
DEVICES --> DEVICE_PROPERTIES[GET /device-properties]
DEVICES --> DEVICE_BOUNDARY_MAP[GET /device-boundaries]

%% Vulnerabilities
VULNS --> VULN_LIST[GET /vulnerabilities]
VULN_LIST --> VULN_ARRAY[vulnerabilities (array)]
VULN_LIST --> VULN_PAGINATION[pagination]

VULN_ARRAY --> VULN_ID[id]
VULN_ARRAY --> VULN_CVE[cve]
VULN_ARRAY --> VULN_SEVERITY[severity]
VULN_ARRAY --> VULN_DEVICE[deviceId]

%% Users
USERS --> USER_LIST[GET /users]
USER_LIST --> USER_ARRAY[users (array)]
USER_LIST --> USER_PAGINATION[pagination]

USER_ARRAY --> USER_ID[id]
USER_ARRAY --> USER_EMAIL[email]
USER_ARRAY --> USER_USERNAME[username]
USER_ARRAY --> USER_ROLE[role]
USER_ARRAY --> USER_ACTIVE[isActive]
USER_ARRAY --> USER_2FA[twoFactorAuthentication]

%% Boundaries
BOUNDARIES --> BOUNDARY_LIST[GET /boundaries]
BOUNDARY_LIST --> BOUNDARY_ARRAY[boundaries (array)]
BOUNDARY_LIST --> BOUNDARY_PAGINATION[pagination]

BOUNDARY_ARRAY --> BOUNDARY_ID[id]
BOUNDARY_ARRAY --> BOUNDARY_NAME[name]
BOUNDARY_ARRAY --> BOUNDARY_TYPE[type]

%% Integrations
INTEGRATIONS --> INTEGRATION_LIST[GET /integrations]
INTEGRATION_LIST --> INTEGRATION_ARRAY[integrations (array)]
INTEGRATION_LIST --> INTEGRATION_PAGINATION[pagination]

INTEGRATION_ARRAY --> INTEGRATION_ID[id]
INTEGRATION_ARRAY --> INTEGRATION_NAME[name]
INTEGRATION_ARRAY --> INTEGRATION_STATE[integrationState]
INTEGRATION_ARRAY --> INTEGRATION_STATS[statistics]

%% Policies
POLICIES --> POLICY_LIST[GET /policies]
POLICY_LIST --> POLICY_ARRAY[policies (array)]

%% Reports
REPORTS --> REPORT_LIST[GET /reports]
REPORT_LIST --> REPORT_ARRAY[reports (array)]

%% Roles
ROLES --> ROLE_LIST[GET /roles]
ROLE_LIST --> ROLE_ARRAY[roles (array)]

%% Search
SEARCH --> SEARCH_QUERY[POST /search]
SEARCH_QUERY --> SEARCH_RESULTS[results (array)]

%% Sites
SITES --> SITE_LIST[GET /sites]
SITE_LIST --> SITE_ARRAY[sites (array)]

%% Collectors
COLLECTORS --> COLLECTOR_LIST[GET /collectors]
COLLECTOR_LIST --> COLLECTOR_ARRAY[collectors (array)]
