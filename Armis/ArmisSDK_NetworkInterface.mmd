flowchart LR

 API["GET /api/v1/networkinterfaces"]

 API --> NET_IF_LIST[networkinterfaces]

    %% Identity
    NET_IF --> IF_NAME["name (0..1)"]
    NET_IF --> IF_ALIAS["alias (0..1)"]
    NET_IF --> IF_TYPE["type (0..1)"]
    NET_IF --> IF_BRAND["brand (0..1)"]
    NET_IF --> IF_DESCRIPTION["description (0..1)"]

    %% Addressing — last-seen only
    NET_IF --> IF_MAC["mac_address (0..1)"]
    NET_IF --> IF_IPV4["ipv4_address (0..1)"]
    NET_IF --> IF_IPV6["ipv6_address (0..1)"]

    %% Wireless
    NET_IF --> IF_CHANNELS["channels (0..*)"]
    NET_IF --> IF_BROADCAST_SSID["broadcast_ssid (0..1)"]
    NET_IF --> IF_HIDDEN["hidden_broadcast_ssid (0..1)"]
    NET_IF --> IF_LAST_SSID["last_connected_ssid (0..1)"]

    %% VLAN
    NET_IF --> IF_VLAN["vlan (0..1)"]
