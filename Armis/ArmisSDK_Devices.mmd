flowchart LR

DEVICE["Device"]

%% Core Identity
DEVICE --> DEVICE_ID["device_id (1)"]
DEVICE --> DISPLAY["display (0..1)"]
DEVICE --> CATEGORY["category (0..1)"]
DEVICE --> TYPE["type (0..1)"]
DEVICE --> BRAND["manufacturer / brand (0..1)"]
DEVICE --> MODEL["model (0..1)"]
DEVICE --> BUSINESS_IMPACT["businessImpact (0..1)"]

%% Visibility & Risk
DEVICE --> VISIBILITY["visibility (Full | Limited)"]
DEVICE --> RISK_LEVEL["riskLevel (0..1)"]
DEVICE --> PURDUE_LEVEL["purdueLevel (0..1)"]

%% Time
DEVICE --> FIRST_SEEN["firstSeen (0..1)"]
DEVICE --> LAST_SEEN["lastSeen (0..1)"]

%% Names
DEVICE --> NAMES["names (0..N strings)"]

%% Network Identity
DEVICE --> IPV4["ipv4_addresses (0..N)"]
DEVICE --> IPV6["ipv6_addresses (0..N)"]
DEVICE --> MACS["mac_addresses (0..N)"]
DEVICE --> SERIALS["serial_numbers (0..N)"]

%% Tags
DEVICE --> TAGS["tags (0..N)"]

%% Boundaries
DEVICE --> BOUNDARIES["boundaries (0..N)"]
BOUNDARIES --> BOUNDARY_ID["boundary.id"]
BOUNDARIES --> BOUNDARY_NAME["boundary.name"]

%% Site
DEVICE --> SITE["site (0..1)"]
SITE --> SITE_ID["site.id"]
SITE --> SITE_NAME["site.name"]
SITE --> SITE_LOCATION["site.location"]

%% Sensor
DEVICE --> SENSOR["sensor (0..1)"]
SENSOR --> SENSOR_NAME["sensor.name"]
SENSOR --> SENSOR_TYPE["sensor.type"]

%% Data Sources
DEVICE --> DATASOURCES["dataSources (0..N)"]
DATASOURCES --> DS_NAME["name"]
DATASOURCES --> DS_TYPES["types (0..N)"]
DATASOURCES --> DS_FIRST_SEEN["firstSeen"]
DATASOURCES --> DS_LAST_SEEN["lastSeen"]

%% Users
DEVICE --> USERS["userIds (0..N)"]
