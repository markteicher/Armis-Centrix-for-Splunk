flowchart LR

    DEVICES_API["GET /api/v1/devices"]

    DEVICES_API --> PAGINATION
    DEVICES_API --> DEVICES_LIST

    PAGINATION --> COUNT["count"]
    PAGINATION --> NEXT["next"]
    PAGINATION --> PREV["prev"]
    PAGINATION --> TOTAL["total"]

    DEVICES_LIST --> DEVICE["Device"]

    %% Core Identity
    DEVICE --> DEVICE_ID["device_id (1)"]
    DEVICE --> DISPLAY["display"]
    DEVICE --> NAMES["names (0..*)"]

    %% Classification
    DEVICE --> BRAND["brand"]
    DEVICE --> CATEGORY["category"]
    DEVICE --> TYPE["type"]
    DEVICE --> MODEL["model"]
    DEVICE --> BUSINESS_IMPACT["businessImpact"]

    %% Risk & Purdue
    DEVICE --> RISK_LEVEL["riskLevel"]
    DEVICE --> PURDUE_LEVEL["purdueLevel"]
    DEVICE --> VISIBILITY["visibility"]

    %% Temporal
    DEVICE --> FIRST_SEEN["firstSeen"]
    DEVICE --> LAST_SEEN["lastSeen"]

    %% Network Identity (multi-valued)
    DEVICE --> IPV4["ipv4_addresses (0..*)"]
    DEVICE --> IPV6["ipv6_addresses (0..*)"]
    DEVICE --> MACS["mac_addresses (0..*)"]

    %% Serial Numbers
    DEVICE --> SERIALS["serial_numbers (0..*)"]

    %% Tags
    DEVICE --> TAGS["tags (0..*)"]

    %% Users
    DEVICE --> USERS["userIds (0..*)"]

    %% Site Relationship
    DEVICE --> SITE["site (0..1)"]
    SITE --> SITE_ID["site.id"]
    SITE --> SITE_NAME["site.name"]
    SITE --> SITE_LOCATION["site.location"]

    %% Boundaries (many-to-many)
    DEVICE --> BOUNDARIES["boundaries (0..*)"]
    BOUNDARIES --> BOUNDARY_ID["boundary.id"]
    BOUNDARIES --> BOUNDARY_NAME["boundary.name"]

    %% Data Sources (discovery provenance)
    DEVICE --> DATA_SOURCES["dataSources (0..*)"]
    DATA_SOURCES --> DS_NAME["name"]
    DATA_SOURCES --> DS_TYPES["types (0..*)"]
    DATA_SOURCES --> DS_FIRST_SEEN["firstSeen"]
    DATA_SOURCES --> DS_LAST_SEEN["lastSeen"]

    %% Sensor
    DEVICE --> SENSOR["sensor (0..1)"]
    SENSOR --> SENSOR_NAME["name"]
    SENSOR --> SENSOR_TYPE["type"]

    %% Network Interfaces
    DEVICE --> INTERFACES["networkInterfaces (0..*)"]
    INTERFACES --> IF_NAME["interface name"]
    INTERFACES --> IF_TYPE["interface type"]
