flowchart LR

    DEV_API["GET /api/v1/devices"]

    DEV_API --> RESPONSE

    RESPONSE --> DEVICE

    %% Core Identity
    subgraph IDENTITY["Device Identity"]
        DEVICE --> ID["id"]
        DEVICE --> NAME["name"]
        DEVICE --> NAMES["names"]
        DEVICE --> TYPE["type"]
        DEVICE --> CATEGORY["category"]
        DEVICE --> VISIBILITY["visibility"]
    end

    %% Risk & Classification
    subgraph RISK["Risk and Classification"]
        DEVICE --> RISK_LEVEL["riskLevel"]
        DEVICE --> BUSINESS_IMPACT["businessImpact"]
        DEVICE --> PURDUE["purdueLevel"]
    end

    %% Network Identifiers
    subgraph NETWORK["Network Identifiers"]
        DEVICE --> IP["ipAddress"]
        DEVICE --> IPV6["ipv6"]
        DEVICE --> MAC["macAddress"]
    end

    %% Platform Details
    subgraph PLATFORM["Platform Details"]
        DEVICE --> MANUFACTURER["manufacturer"]
        DEVICE --> MODEL["model"]
        DEVICE --> OS["operatingSystem"]
        DEVICE --> OS_VERSION["operatingSystemVersion"]
    end

    %% Lifecycle
    subgraph LIFECYCLE["Lifecycle"]
        DEVICE --> FIRST_SEEN["firstSeen"]
        DEVICE --> LAST_SEEN["lastSeen"]
    end

    %% Context
    subgraph CONTEXT["Context"]
        DEVICE --> BOUNDARIES["boundaries"]
        DEVICE --> TAGS["tags"]
        DEVICE --> USER_IDS["userIds"]
    end

    %% Sensor
    subgraph SENSOR["Sensor"]
        DEVICE --> SENSOR_NODE["sensor"]
        SENSOR_NODE --> SENSOR_NAME["name"]
        SENSOR_NODE --> SENSOR_TYPE["type"]
    end

    %% Site
    subgraph SITE["Site"]
        DEVICE --> SITE_NODE["site"]
        SITE_NODE --> SITE_NAME["name"]
        SITE_NODE --> SITE_LOCATION["location"]
    end

    %% Data Sources
    subgraph DATA_SOURCES["Data Sources"]
        DEVICE --> DS["dataSources"]
        DS --> DS_NAME["name"]
        DS --> DS_TYPES["types"]
        DS --> DS_FIRST["firstSeen"]
        DS --> DS_LAST["lastSeen"]
    end

    %% Pagination
    subgraph PAGINATION["Pagination"]
        RESPONSE --> COUNT["count"]
        RESPONSE --> NEXT["next"]
        RESPONSE --> PREV["prev"]
        RESPONSE --> TOTAL["total"]
    end
