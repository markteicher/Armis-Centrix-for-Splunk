<!--
=============================================================================
 default/data/ui/views/armis_vulnerabilities_overview.xml
 Armis Centrix™ for Splunk App
 🛡️ Vulnerabilities Overview
=============================================================================

• ⏱️ Time Range
• 🔢 Total Open Vulnerabilities
• 📊 Open Vulnerabilities By Severity
• 📈 Open Vulnerabilities By Status
• 📉 Open Vulnerabilities Over Time
• 📊 Open Vulnerabilities Over Time By Severity
• 📋 All Open Vulnerabilities
• 🎛️ Severity
• 🎛️ CVSS Score

• 🔎 Base Search: Open Vulnerabilities
• 🔎 Base Search: Open Vulnerabilities Over Time
• 🎛️ Filter: Time Range
• 🎛️ Filter: Severity
• 🎛️ Filter: CVSS Score
• 🔗 Drilldown: Search View
• 🔗 Drilldown: NIST NVD
• 🔗 Drilldown: Affected Devices
=============================================================================
-->

<form version="1.1" script="severity_multiselect.js">
  <label>🛡️ Vulnerabilities Overview</label>

  <search id="base">
    <query>`get_armis_index` sourcetype="armis:cve"
| stats latest(*) as * by id
| where status="Open"</query>
    <earliest>$time_range.earliest$</earliest>
    <latest>$time_range.latest$</latest>
  </search>

  <search id="time_base">
    <query>`get_armis_index` sourcetype="armis:cve"
| sort 0 - _time
| dedup id
| stats latest(*) as * by _time id
| where status="Open"</query>
    <earliest>$time_range.earliest$</earliest>
    <latest>$time_range.latest$</latest>
  </search>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time_range">
      <label>⏱️ Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <single>
        <title>🔢 Total Open Vulnerabilities</title>
        <search base="base">
          <query>stats count</query>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>📊 Open Vulnerabilities By Severity</title>
        <search base="base">
          <query>| eval severity=if(severity=="null","N/A",severity)
| stats count by severity</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <condition match="like('click.value',&quot;N/A&quot;)">
            <link target="_blank">search?q=`get_armis_index` sourcetype="armis:cve" | stats latest(*) as * by id | where status="Open" | search severity="null"&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
          <condition>
            <link target="_blank">search?q=`get_armis_index` sourcetype="armis:cve" | stats latest(*) as * by id | where status="Open" | search severity="$click.value$"&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
        </drilldown>
      </chart>
    </panel>

    <panel>
      <chart>
        <title>📈 Open Vulnerabilities By Status</title>
        <search>
          <query>`get_armis_index` sourcetype="armis:cve"
| stats latest(*) as * by id
| stats count by status</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.sliceCollapsingThreshold">0</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=`get_armis_index` sourcetype="armis:cve" | stats latest(*) as * by id | where status="$click.value$"&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>📉 Open Vulnerabilities Over Time</title>
        <search base="time_base">
          <query>| timechart count span=1d</query>
        </search>
        <option name="charting.axisTitleY.text">Open Vulnerabilities Count</option>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.placement">none</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=`get_armis_index` sourcetype="armis:cve" | sort 0 - _time | dedup id | stats latest(*) as * by _time id | where status="Open"&amp;earliest=$earliest$&amp;latest=$latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>📊 Open Vulnerabilities Over Time By Severity</title>
        <search base="time_base">
          <query>| timechart count by severity</query>
        </search>
        <option name="charting.axisTitleY.text">Open Vulnerabilities Count</option>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=`get_armis_index` sourcetype="armis:cve" severity="$click.name2$" | sort 0 - _time | dedup id | stats latest(*) as * by _time id | where status="Open"&amp;earliest=$earliest$&amp;latest=$latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>📋 All Open Vulnerabilities</title>

      <input type="multiselect" token="pick_severity" searchWhenChanged="true" id="multiselect_severities">
        <label>🎛️ Severity</label>
        <delimiter> OR severity="</delimiter>
        <fieldForLabel>severity</fieldForLabel>
        <fieldForValue>severity</fieldForValue>
        <search base="base">
          <query>| stats count by severity</query>
        </search>
        <choice value="*">ALL</choice>
        <default>*</default>
        <prefix>"</prefix>
        <valueSuffix>"</valueSuffix>
      </input>

      <input type="text" token="cve_score" searchWhenChanged="true">
        <label>🎛️ CVSS Score</label>
        <change>
          <condition match="$value$([&lt;&gt;]=?\d+(\.\d+)?|=\d+(\.\d+)?)">
            <set token="cve_score">$value$</set>
          </condition>
        </change>
        <default>&gt;=0</default>
      </input>

      <table id="table1">
        <search base="base">
          <query>| eval cvssScore = if(cvssScore == "null", 0, cvssScore)
| eval numOfExploits = if(numOfExploits == "null", 0, numOfExploits)
| eval nvd="NIST"
| search severity=$pick_severity$ cvssScore $cve_score$
| sort -affectedDevicesCount -publishedDate
| table id, nvd, severity, cvssScore, numOfExploits, affectedDevicesCount, publishedDate, host
| rename id as "ID", nvd as "National Vulnerability Database", severity as "Severity", cvssScore as "CVSS Score", numOfExploits as "Num Of Exploits", affectedDevicesCount as "Affected Devices Count", publishedDate as "Published Date"</query>
        </search>
        <option name="drilldown">cell</option>
        <fields>["ID","National Vulnerability Database","Severity","CVSS Score","Num Of Exploits","Affected Devices Count","Published Date"]</fields>
        <drilldown>
          <condition field="ID">
            <link target="_blank">search?q=`get_armis_index` sourcetype="armis:cve" | stats latest(*) as * by id | where status="Open" | search id="$row.ID$"&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
          <condition field="National Vulnerability Database">
            <link target="_blank"><![CDATA[https://nvd.nist.gov/vuln/detail/$row.ID$]]></link>
          </condition>
          <condition field="CVSS Score"></condition>
          <condition field="Num Of Exploits"></condition>
          <condition field="Affected Devices Count">
            <link target="_blank">/app/armis/affected_devices?cveUID="$row.ID$"&amp;earliest=0</link>
          </condition>
          <condition field="Published Date"></condition>
        </drilldown>
      </table>
    </panel>
  </row>
</form>
