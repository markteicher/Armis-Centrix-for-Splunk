<!--
=============================================================================
 default/data/ui/views/armis_documentation.xml
 Armis Centrix™ for Splunk App
 Documentation Hub (tile layout)
=============================================================================
-->
<dashboard version="1.1" theme="light">
  <label>📚 Armis Centrix™ for Splunk App Documentation Hub</label>

  <row>
    <panel>
      <html>

        <style>
          .portal-grid{
            display:grid;
            grid-template-columns:repeat(3,1fr);
            gap:22px;
            margin-top:20px;
          }
          .portal-tile{
            background:#ffffff;
            border:1px solid #e5e5e5;
            border-radius:8px;
            padding:22px;
            text-align:center;
            transition:all .18s ease;
          }
          .portal-tile:hover{
            box-shadow:0 4px 14px rgba(0,0,0,.18);
            transform:translateY(-2px);
          }
          .portal-icon{font-size:34px;margin-bottom:10px;}
          .portal-title{font-size:15px;font-weight:600;}
          .portal-link{text-decoration:none;color:inherit;display:block;}
        </style>

        <div class="portal-grid">

          <!-- Armis Platform -->
          <a class="portal-link" href="https://www.armis.com/platform/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🌐</div>
              <div class="portal-title">Armis Centrix™ Platform</div>
            </div>
          </a>
          <a class="portal-link" href="https://www.armis.com/resources/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📘</div>
              <div class="portal-title">Armis Resource Library</div>
            </div>
          </a>
          <a class="portal-link" href="https://www.armis.com/blog/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📝</div>
              <div class="portal-title">Armis Security Blog</div>
            </div>
          </a>
          
    <!-- Exposure & Device Security -->
          <a class="portal-link" href="https://www.armis.com/videos/armis-centrix-for-vulnerability-management-detection-and-response-overview/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🛡️</div>
              <div class="portal-title">Armis Vulnerability MDR Overview</div>
            </div>
          </a>
          <a class="portal-link" href="https://www.armis.com/platform/armis-centrix-for-ot-iot-security/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🏭</div>
              <div class="portal-title">Armis OT / IoT Security</div>
            </div>
          </a>
          <a class="portal-link" href="https://www.armis.com/cybersecurity/health-and-medical/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🏥</div>
              <div class="portal-title">Armis Healthcare and Medical</div>
            </div>
          </a>
          
          <!-- Security Frameworks -->
          <a class="portal-link" href="https://owasp.org/www-project-top-ten/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🔒</div>
              <div class="portal-title">OWASP Top 10</div>
            </div>
          </a>
          <a class="portal-link" href="https://attack.mitre.org/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🎯</div>
              <div class="portal-title">MITRE ATTACK</div>
            </div>
          </a>
          <a class="portal-link" href="https://www.first.org/cvss/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📊</div>
              <div class="portal-title">CVSS Calculator</div>
            </div>
          </a>
          <a class="portal-link" href="https://csrc.nist.gov/publications/detail/sp/800-53/rev-5/final" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📚</div>
              <div class="portal-title">NIST SP 800-53</div>
            </div>
          </a>

      

          <!-- Splunk References -->
          <a class="portal-link" href="https://docs.splunk.com/Documentation/Splunk/latest/Viz/XMLDashboardReference" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📊</div>
              <div class="portal-title">Splunk XML Dashboards</div>
            </div>
          </a>
          <a class="portal-link" href="https://docs.splunk.com/Documentation/Splunk/latest/Admin/Propsconf" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">⚙️</div>
              <div class="portal-title">props.conf</div>
            </div>
          </a>
          <a class="portal-link" href="https://docs.splunk.com/Documentation/Splunk/latest/Admin/Transformsconf" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🔧</div>
              <div class="portal-title">transforms.conf</div>
            </div>
          </a>
          <a class="portal-link" href="https://dev.splunk.com/enterprise/docs/developapps/testvalidate/appinspect/" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📦</div>
              <div class="portal-title">Splunk AppInspect</div>
            </div>
          </a>

        </div>

      </html>
    </panel>
  </row>
</dashboard>
