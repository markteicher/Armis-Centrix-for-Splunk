<!--
=============================================================================
 default/data/ui/views/armis_search.xml
 Armis Centrix™ for Splunk App
 Search Explorer & Cascading Search Filters
=============================================================================

Purpose:
Provide operational visibility into Armis Search API results using scoped
search selections and cascading type filters.

Data Source:
Armis REST API
GET /api/v1/search/

Available Search Scopes:
• activity
• alerts
• auditlog
• applications
• businessApplications
• connections
• devices
• operatingSystems
• riskFactors
• services
• traffic
• users
• vulnerabilities

Example Request:
GET /api/v1/search/?aql=in:activity
GET /api/v1/search/?aql=in:activity type:"Dns Query"

Splunk Source:
index=$index$
sourcetype=armis_search

Required Indexed Request Field:
aql

Expected Result Fields:
data.results{}.activityUUID
data.results{}.title
data.results{}.content
data.results{}.type
data.results{}.protocol
data.results{}.sensor.name
data.results{}.time
data.results{}.deviceIds{}
data.results{}.connectionIds{}
success

Design Standards:
• Enterprise base-search architecture
• Post-process panel searches
• Cascading dropdown filters
• JSON field extraction via spath
• Structured operational sections
• No mvjoin usage

=============================================================================
-->

<dashboard version="1.1" theme="light">
  <label>🔎 Armis Search</label>
  <description>Scoped search explorer for Armis Search API results</description>

  <init>
    <set token="index">armis</set>
  </init>

  <!-- ========================================================= -->
  <!-- Global Filters -->
  <!-- ========================================================= -->

  <fieldset submitButton="false">
    <input type="time" token="time_range">
      <label>Time Range</label>
      <default>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="dropdown" token="search_scope">
      <label>Search</label>
      <choice value="activity">activity</choice>
      <choice value="alerts">alerts</choice>
      <choice value="auditlog">auditlog</choice>
      <choice value="applications">applications</choice>
      <choice value="businessApplications">businessApplications</choice>
      <choice value="connections">connections</choice>
      <choice value="devices">devices</choice>
      <choice value="operatingSystems">operatingSystems</choice>
      <choice value="riskFactors">riskFactors</choice>
      <choice value="services">services</choice>
      <choice value="traffic">traffic</choice>
      <choice value="users">users</choice>
      <choice value="vulnerabilities">vulnerabilities</choice>
      <default>activity</default>
    </input>

    <input type="dropdown" token="type_filter">
      <label>Type</label>
      <choice value="*">All Types</choice>
      <fieldForLabel>type</fieldForLabel>
      <fieldForValue>type</fieldForValue>
      <search>
        <query><![CDATA[
index=$index$ sourcetype=armis_search aql="in:$search_scope$"
| spath path=data.results{} output=results
| mvexpand results
| spath input=results path=type output=type
| search type=*
| stats count by type
| sort type
        ]]></query>
        <earliest>$time_range.earliest$</earliest>
        <latest>$time_range.latest$</latest>
      </search>
      <default>*</default>
    </input>
  </fieldset>

  <!-- ========================================================= -->
  <!-- Base Search -->
  <!-- ========================================================= -->

  <search id="base_armis_search">
    <query><![CDATA[
index=$index$ sourcetype=armis_search aql="in:$search_scope$"
| spath path=data.results{} output=results
| mvexpand results
| spath input=results path=activityUUID output=activityUUID
| spath input=results path=title output=title
| spath input=results path=content output=content
| spath input=results path=type output=type
| spath input=results path=protocol output=protocol
| spath input=results path=sensor.name output=sensor_name
| spath input=results path=time output=event_time
| spath input=results path=deviceIds{} output=deviceIds
| spath input=results path=connectionIds{} output=connectionIds
| eval type_match=if("$type_filter$"="*" OR type="$type_filter$",1,0)
| where type_match=1
| fields - type_match
    ]]></query>
    <earliest>$time_range.earliest$</earliest>
    <latest>$time_range.latest$</latest>
  </search>

  <!-- ========================================================= -->
  <!-- Search Context -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>🧭 Current AQL</title>
      <table>
        <search>
          <query><![CDATA[
| makeresults
| eval aql=if("$type_filter$"="*","in:$search_scope$","in:$search_scope$ type:\"$type_filter$\"")
| table aql
          ]]></query>
        </search>
        <option name="count">1</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>

  <!-- ========================================================= -->
  <!-- Top Metrics -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>🔢 Total Results</title>
      <single>
        <search base="base_armis_search">
          <query><![CDATA[
| stats count
          ]]></query>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <title>🏷️ Distinct Types</title>
      <single>
        <search base="base_armis_search">
          <query><![CDATA[
| stats dc(type)
          ]]></query>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <!-- ========================================================= -->
  <!-- Type Breakdown -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>📋 Results by Type</title>
      <table>
        <search base="base_armis_search">
          <query><![CDATA[
| stats count by type
| sort -count
          ]]></query>
        </search>
        <option name="count">50</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>

  <!-- ========================================================= -->
  <!-- Detailed Listing -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>📑 Search Result Listing</title>
      <table>
        <search base="base_armis_search">
          <query><![CDATA[
| sort -_time
| table event_time activityUUID title content type protocol sensor_name deviceIds connectionIds
          ]]></query>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
</dashboard>
