<!--
=============================================================================
 default/data/ui/views/armis_auditlog.xml
 Armis Centrix™ for Splunk App
 Audit Log Monitoring & User Action Visibility
=============================================================================

Purpose:
Provide operational visibility into Armis audit log events using the auditlog
search dataset. This dashboard enhances visibility into user actions and
system events to improve monitoring, support compliance, and streamline
troubleshooting.

Data Source:
Armis REST API
GET /api/v1/search/?aql=in:auditLog

Splunk Source:
index=$index$
sourcetype=armis_auditlog

Expected Fields:
data.results{}.action
data.results{}.additionalInfo.data
data.results{}.additionalInfo.type
data.results{}.id
data.results{}.time
data.results{}.timeUtc
data.results{}.trigger
data.results{}.user
data.results{}.userIp
data.count
data.next
data.prev
data.total
success

Design Standards:
• Enterprise base-search architecture
• Post-process panel searches
• JSON field extraction via spath
• Structured operational sections

=============================================================================
-->

<dashboard version="1.1" theme="light">
  <label>📘 Armis Audit Log</label>
  <description>Operational monitoring and visibility into Armis audit log activity</description>

  <init>
    <set token="index">armis</set>
  </init>

  <!-- ========================================================= -->
  <!-- Global Filters -->
  <!-- ========================================================= -->

  <fieldset submitButton="false">
    <input type="time" token="time_range">
      <label>Time Range</label>
      <default>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <!-- ========================================================= -->
  <!-- Base Search -->
  <!-- ========================================================= -->

  <search id="base_auditlog">
    <query><![CDATA[
index=$index$ sourcetype=armis_auditlog
| spath path=data.results{} output=results
| mvexpand results
| spath input=results path=action output=action
| spath input=results path=additionalInfo.data output=additionalInfoData
| spath input=results path=additionalInfo.type output=additionalInfoType
| spath input=results path=id output=id
| spath input=results path=time output=time
| spath input=results path=timeUtc output=timeUtc
| spath input=results path=trigger output=trigger
| spath input=results path=user output=user
| spath input=results path=userIp output=userIp
| dedup id sortby -_time
    ]]></query>
    <earliest>$time_range.earliest$</earliest>
    <latest>$time_range.latest$</latest>
  </search>

  <!-- ========================================================= -->
  <!-- Top Metrics -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>🔢 Total Audit Events</title>
      <single>
        <search base="base_auditlog">
          <query><![CDATA[
| stats count
          ]]></query>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <title>👤 User Action Events</title>
      <single>
        <search base="base_auditlog">
          <query><![CDATA[
| search trigger="User Action"
| stats count
          ]]></query>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <title>🔐 Login Attempts</title>
      <single>
        <search base="base_auditlog">
          <query><![CDATA[
| search action="Login Attempt"
| stats count
          ]]></query>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <!-- ========================================================= -->
  <!-- Audit Visibility -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>📋 Audit Events by Action</title>
      <table>
        <search base="base_auditlog">
          <query><![CDATA[
| stats count by action
| sort -count
          ]]></query>
        </search>
        <option name="count">25</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>

    <panel>
      <title>📋 Audit Events by Trigger</title>
      <table>
        <search base="base_auditlog">
          <query><![CDATA[
| stats count by trigger
| sort -count
          ]]></query>
        </search>
        <option name="count">25</option>
        <option name="drilldown">none</option>
      </table>
    </panel>

    <panel>
      <title>📋 Audit Events by User</title>
      <table>
        <search base="base_auditlog">
          <query><![CDATA[
| stats count by user
| sort -count
| head 25
          ]]></query>
        </search>
        <option name="count">25</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>

  <!-- ========================================================= -->
  <!-- Source Visibility -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>📋 Audit Events by User IP</title>
      <table>
        <search base="base_auditlog">
          <query><![CDATA[
| stats count by userIp
| sort -count
          ]]></query>
        </search>
        <option name="count">25</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>

  <!-- ========================================================= -->
  <!-- Detailed Listing -->
  <!-- ========================================================= -->

  <row>
    <panel>
      <title>📑 Audit Log Detailed Listing</title>
      <table>
        <search base="base_auditlog">
          <query><![CDATA[
| sort -timeUtc
| table timeUtc action trigger user userIp additionalInfoType additionalInfoData id
          ]]></query>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">50</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
</dashboard>
