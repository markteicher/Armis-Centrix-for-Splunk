  <!-- API AUTHENTICATION                                              -->
  <!-- =============================================================== -->
  <row>
    <panel>
      <title>API Authentication</title>
      <html><![CDATA[
POST /api/v1/access_token/

URI Parameters

secret-key (string)

Response

{
 "data": {
  "access_token": "<token>",
  "expiration_utc": "<timestamp>"
 },
 "success": true
}

HTTP Status Codes

200 OK
400 Bad request
      ]]></html>
    </panel>
  </row>

