  <!-- SEARCH API                                                      -->
  <!-- =============================================================== -->
  <row>
    <panel>
      <title>Search API</title>
      <html><![CDATA[
GET /api/v1/search/?aql=<query>

Datasets

in:devices
in:alerts
in:activity
in:connections
in:auditLog

Query Parameters

aql
includeTotal
includeSample
length
from

Example

GET /api/v1/search/?aql=in:devices
      ]]></html>
    </panel>
  </row>

