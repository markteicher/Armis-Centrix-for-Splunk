<dashboard version="1.1" theme="light">
  <label>🧭 Armis Centrix™ – Feature Navigation Hub</label>

  <row>
    <panel>
      <html>

        <!-- ─────────── Tile-grid style (reuse across hubs) ─────────── -->
        <style>
          .portal-grid{
            display:grid;
            grid-template-columns:repeat(4,1fr);
            gap:22px;
            margin-top:20px;
          }
          .portal-tile{
            background:#ffffff;
            border:1px solid #e5e5e5;
            border-radius:8px;
            padding:22px;
            text-align:center;
            transition:all .18s ease;
          }
          .portal-tile:hover{
            box-shadow:0 4px 14px rgba(0,0,0,.18);
            transform:translateY(-2px);
          }
          .portal-icon{font-size:34px;margin-bottom:10px;}
          .portal-title{font-size:15px;font-weight:600;}
          .portal-link{text-decoration:none;color:inherit;display:block;}
        </style>

        <!-- ─────────── Grid of view links ─────────── -->
        <div class="portal-grid">

          <!-- Overview -->
          <a class="portal-link" href="armis_overview" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🧭</div><div class="portal-title">Overview</div></div>
          </a>

          <!-- Assets -->
          <a class="portal-link" href="armis_assets" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🖥️</div><div class="portal-title">Assets</div></div>
          </a>

          <!-- Asset Intelligence -->
          <a class="portal-link" href="armis_asset_intel" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🧠</div><div class="portal-title">Asset&nbsp;Intelligence</div></div>
          </a>

          <!-- Asset Comms -->
          <a class="portal-link" href="armis_asset_comms" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🌐</div><div class="portal-title">Asset&nbsp;Communications</div></div>
          </a>

          <!-- Alerts -->
          <a class="portal-link" href="armis_alerts" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🚨</div><div class="portal-title">Alerts</div></div>
          </a>

          <!-- Alerts by Severity -->
          <a class="portal-link" href="armis_alerts_severity" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🔥</div><div class="portal-title">Alerts&nbsp;– Severity</div></div>
          </a>

          <!-- Vulnerabilities -->
          <a class="portal-link" href="armis_vulns" target="_blank">
            <div class="portal-tile"><div class="portal-icon">🧬</div><div class="portal-title">Vulnerabilities</div></div>
          </a>

          <!-- VIPR -->
