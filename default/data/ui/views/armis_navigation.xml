<!--
=============================================================================
 default/data/ui/views/armis_navigation.xml
 Armis Centrix™ for Splunk App
 Navigation Hub
=============================================================================

PURPOSE

Tile-based landing page linking to every functional view.
Section-header tiles (grey, full-width) break the grid into logical
groups. Matches the same “portal tile” design used in the
Documentation Hub.

=============================================================================
-->
<dashboard version="1.1" theme="light">
  <label>🧭 Armis Centrix™ – Navigation Hub</label>

  <row>
    <panel>
      <html>

        <style>
          .portal-grid{
            display:grid;
            grid-template-columns:repeat(4,1fr);
            gap:22px;
            margin-top:20px;
          }
          .portal-tile{
            background:#ffffff;
            border:1px solid #e5e5e5;
            border-radius:8px;
            padding:22px;
            text-align:center;
            transition:all .18s ease;
          }
          .portal-tile:hover{
            box-shadow:0 4px 14px rgba(0,0,0,.18);
            transform:translateY(-2px);
          }
          .portal-icon{font-size:34px;margin-bottom:10px;}
          .portal-title{font-size:15px;font-weight:600;}
          .portal-link{text-decoration:none;color:inherit;display:block;}
          .portal-header{
            background:#f5f5f5;
            border:1px solid #d0d0d0;
            cursor:default;
            grid-column:span 4;
            font-size:16px;
            font-weight:700;
            padding:18px 22px;
          }
        </style>

        <div class="portal-grid">

          <!-- Overview -->
          <div class="portal-tile portal-header">Overview</div>
          <a class="portal-link" href="/app/armis/armis_navigation">
            <div class="portal-tile">
              <div class="portal-icon">🧭</div>
              <div class="portal-title">Overview</div>
            </div>
          </a>

          <!-- Devices and Discovery -->
          <div class="portal-tile portal-header">Devices and Discovery</div>
          <a class="portal-link" href="/app/armis/armis_devices">
            <div class="portal-tile"><div class="portal-icon">🖥️</div><div class="portal-title">Devices</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_devices_overview">
            <div class="portal-tile"><div class="portal-icon">📊</div><div class="portal-title">Devices Overview</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_collectors_product_listing_aging_view">
            <div class="portal-tile"><div class="portal-icon">📡</div><div class="portal-title">Collectors</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_networks">
            <div class="portal-tile"><div class="portal-icon">🌐</div><div class="portal-title">Networks</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_boundaries">
            <div class="portal-tile"><div class="portal-icon">🛑</div><div class="portal-title">Boundaries</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_asset_intelligence">
