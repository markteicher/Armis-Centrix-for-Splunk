            <div class="portal-tile"><div class="portal-icon">🎯</div><div class="portal-title">VIPR&nbsp;Prioritization</div></div>
          </a>

          <!-- Exposure Analytics -->
          <a class="portal-link" href="armis_exposure_analytics" target="_blank">
            <div class="portal-tile"><div class="portal-icon">📊</div><div class="portal-title">Exposure&nbsp;Analytics</div></div>
