          <a class="portal-link" href="/app/armis/armis_policies">
            <div class="portal-tile"><div class="portal-icon">🛡️</div><div class="portal-title">Policies</div></div>
          </a>

          <!-- Logs and Health -->
          <div class="portal-tile portal-header">Logs and Health</div>
          <a class="portal-link" href="/app/armis/armis_activity_log">
            <div class="portal-tile"><div class="portal-icon">📜</div><div class="portal-title">Logging</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_auditlog">
            <div class="portal-tile"><div class="portal-icon">📜</div><div class="portal-title">Audit Logs</div></div>
          </a>
          <a class="portal-link" href="/app/armis/armis_error_logs">
            <div class="portal-tile"><div class="portal-icon">⚠️</div><div class="portal-title">Error Logs</div></div>
