<!--
=============================================================================
 default/data/ui/views/armis_integrations_status.xml
 Armis Centrix™ for Splunk App
 Integrations Status Monitoring & Operational Inventory
=============================================================================

Purpose:
Provide operational visibility into Armis integrations status using the
integration status lookup dataset. This dashboard presents summary metrics,
status distribution, current state visibility, collector coverage, and
detailed integration records.

Data Source:
Lookup File
armis_integrations_status.csv

Splunk Source:
| inputlookup armis_integrations_status.csv

Expected Fields:
Collector
Instance
Name
Types
Status First Reported
Last Edit At
Last Status Report
Current State
Status
Host / Address

Design Standards:
• Enterprise base-search architecture
• Post-process panel searches
• Lookup-backed operational dashboard
• Shared source search across all panels
• Structured operational sections
• No spath usage
• No field-name redesign
• No helper fields
• No invented display logic

=============================================================================
--><dashboard version="1.1" theme="light">
  <label>🔌 Armis Integrations Status</label>
  <description>Operational monitoring and summary analytics for Armis integrations status</description>
  <!-- ===================== BASE SEARCH ===================== -->
  <search id="base_armis_integrations_status">
    <query>
      <![CDATA[
| inputlookup armis_integrations_status.csv
      ]]>
    </query>
    <earliest>-24h@h</earliest>
    <latest>now</latest>
  </search>
  <!-- ===================== TOP METRICS ===================== -->
  <!-- ===================== STATUS BREAKDOWN ===================== -->
  <!-- ===================== DATA QUALITY ===================== -->
  <!-- ===================== NAME / INSTANCE BREAKDOWN ===================== -->
  <!-- ===================== DETAILED LISTING ===================== -->
  <row>
    <panel>
      <title>🔢 Total Integrations</title>
      <single>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[ | stats count ]]>
          </query>
        </search>
        <option name="drilldown">all</option>
      </single>
    </panel>
    <panel>
      <title>📊 Integrations by Status</title>
      <table>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[
| stats count by Status
| sort -count
          ]]>
          </query>
        </search>
        <option name="count">20</option>
        <option name="drilldown">cell</option>
      </table>
    </panel>
    <panel>
      <title>📈 Integrations by Current State</title>
      <table>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[
| stats count by "Current State"
| sort -count
          ]]>
          </query>
        </search>
        <option name="count">20</option>
        <option name="drilldown">cell</option>
      </table>
    </panel>
    <panel>
      <title>🧬 Integrations by Types</title>
      <table>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[
| stats count by Types
| sort -count
          ]]>
          </query>
        </search>
        <option name="count">20</option>
        <option name="drilldown">cell</option>
      </table>
    </panel>
    <panel>
      <title>📋 Integrations by Name</title>
      <table>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[
| stats count by Name
| sort -count
| head 20
          ]]>
          </query>
        </search>
        <option name="count">20</option>
        <option name="drilldown">cell</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>🧱 Integrations by Collector</title>
      <table>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[
| stats count by Collector
| sort -count
| head 20
          ]]>
          </query>
        </search>
        <option name="count">20</option>
        <option name="drilldown">cell</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>📋 Integrations Status Detailed Listing</title>
      <table>
        <search base="base_armis_integrations_status">
          <query>
            <![CDATA[
| fields - "Host / Address"
| table Collector, Instance, "Name", "Types", "Status First Reported", "Last Edit At", "Last Status Report", "Current State", "Status"
          ]]>
          </query>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
<row>
  <panel>
    <title>📈 Active / Total Integrations (%)</title>
    <single>
      <search base="base_armis_integrations_status">
        <query><![CDATA[
| eval active_flag=if('Current State'="Active",1,0)
| stats sum(active_flag) as active count as total
| eval pct=round((active/total)*100,2)."%"
| table pct
        ]]></query>
      </search>
      <option name="drilldown">none</option>
    </single>
  </panel>

  <panel>
    <title>⚠️ No Network Traffic Error / Total Integrations (%)</title>
    <single>
      <search base="base_armis_integrations_status">
        <query><![CDATA[
| eval error_flag=if(Status="No Network Traffic Error",1,0)
| stats sum(error_flag) as affected count as total
| eval pct=round((affected/total)*100,2)."%"
| table pct
        ]]></query>
      </search>
      <option name="drilldown">none</option>
    </single>
  </panel>
</row>

</dashboard>
